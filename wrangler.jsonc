{
  "name": "casadelangosta",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "kv_namespaces": [
    {
      "binding": "ADMIN_KV",
      "id": "211323d567354b8797a7bf3e0d6c899a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "GALLERY_IMAGES",
      "bucket_name": "gallery-images"
    }
  ]
}
